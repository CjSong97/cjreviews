---
import { getPublishedPosts, getPostBlocks, getRelatedPosts } from "../../lib/notion/adapter"
import type { ReviewPost } from "../../lib/cms/types"
import BaseLayout from "../../layouts/BaseLayout.astro"
import ReviewHero from "../../components/ReviewHero.svelte"
import NotionRenderer from "../../components/NotionRenderer.svelte"
import RelatedPosts from "../../components/RelatedPosts.svelte"

export async function getStaticPaths() {
  const posts = await getPublishedPosts()
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props as { post: ReviewPost }
const [blocks, related] = await Promise.all([
  getPostBlocks(post.id),
  getRelatedPosts(post, { limit: 4 }),
])

const seoTitle = post.seoTitle ?? post.title
const seoDesc = post.seoDescription ?? post.description ?? ""
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  ogImage={post.coverImage ?? undefined}
  canonicalUrl={Astro.url.href}
>
  <div class="page-wrap">
    <ReviewHero {post} client:load />

    <article class="article-body">
      <NotionRenderer {blocks} client:load />
    </article>

    <RelatedPosts posts={related} client:load />
  </div>
</BaseLayout>

<style>
  .page-wrap {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .article-body {
    max-width: 72ch;
    margin: 0 auto;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text, #111827);
  }
</style>
